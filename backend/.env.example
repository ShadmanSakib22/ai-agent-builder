# ─────────────────────────────────────────────────────────────
# AI Agent Builder — Backend environment
# Copy this file to .env and fill in the values you want to use
# as SERVER-SIDE defaults (optional — users can always pass their
# own key via the API request body).
# ─────────────────────────────────────────────────────────────

# CORS origins that are allowed to call the API (comma-separated)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Optional: set a default API key per provider so the frontend
# doesn't need to send one (useful for a shared playground).
# NEVER commit real keys to source control.
# DEFAULT_ANTHROPIC_KEY=
# DEFAULT_OPENAI_KEY=
# DEFAULT_GEMINI_KEY=
# DEFAULT_DEEPSEEK_KEY=
# DEFAULT_MOONSHOT_KEY=
# DEFAULT_OPENROUTER_KEY=
# DEFAULT_LOCAL_LLM_KEY=ollama
